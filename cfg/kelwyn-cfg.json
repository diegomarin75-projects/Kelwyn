{
  
  //File paths
  "history_file": ".kelwyn_history",
  "debug_log_file": ".kelwyn_debug.log",
  
  //Alias definitions
  "aliases":{
    "dir":{"enabled":true,"command":"ls -v"},
    "copy":{"enabled":true,"command":"$copy"},
    "del":{"enabled":true,"command":"$del"},
    "rmdir":{"enabled":true,"command":"$rmdir"},
    "mkdir":{"enabled":true,"command":"$mkdir"}
  },
  
  //System prompt
  "system_prompt":"{%94m%}[<month>/<day>·<hour><min><sec>]{%0m%}<beta> {%92m%}<cwd>{%0m%}<git> {%90m%}>{%0m%} ",
  
  //Sizes
  "max_debug_lines":5000,
  "max_history_commands":25000,
  "completer_maximun_height_percent":40,
  "command_box_maximun_height_percent":40,

  //Git info timeout (seconds)
  "git_info_timeout_secs":10,
  
  //Colors (use hex format #RRGGBB or standard ANSI color names)
  "error_message_color"                :"#FF0000",
  "ghost_suggestion_color"             :"#505050",
  "selection_foreground_color"         :"#FFFF00",
  "selection_background_color"         :"#0000FF",
  "completer_option_highlight_color"   :"#303030",
  "completer_option_background_color"  :null,
  "completer_status_foreground_color"  :"#909090",
  "completer_status_background_color"  :"#303030",
  "command_box_item_foreground_color"  :"#7F7F7F",
  "command_box_item_highlight_color"   :"#0000C0",
  "command_box_item_background_color"  :"#202020",
  "command_box_status_foreground_color":"#C0C0C0",
  "command_box_status_background_color":"#A00000",
  "global_dir_color"                   :"#40B0FF",
  "global_file_color"                  :"#7F7F7F",
  "global_file_error_color"            :"#FF0000",
  "global_dir_header_color"            :"#FF7F7F",
  "git_clean_color"                    :"#FF5555",
  "git_dirty_color"                    :"#FF50FF",
  "git_conflict_color"                 :"#FFFF00",
  "git_branch_color"                   :"#909090",
  "stable_mode_color"                  :"#007F00",
  "beta_mode_color"                    :"#00FFFF",
  "option_error_color"                 :"#FF0000"
 
